tests/eval_data.json

# Index and runtime data
.kb/index/
.kb/log.md
.kb/taxonomy.yaml
.kb/index/feedback.jsonl
__pycache__/
.kb/__pycache__/
tests/*_results.json

# Editor / OS
.obsidian/
.DS_Store
*.canvas
